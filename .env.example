# Google Maps Platform
# API-Key erstellen: https://console.cloud.google.com/apis/credentials
# Billing-Account erforderlich. Distance Matrix, Geocoding, Places und Directions API aktivieren.
GOOGLE_MAPS_API_KEY=

# Google Gemini – Bildgenerierung (image-gen Skill)
# API-Key erstellen: https://aistudio.google.com/apikey
# Billing-Account erforderlich fuer Image Generation API.
GEMINI_IMAGE_GEN_API_KEY=

# Tavily - breite Webrecherche und Deep Research
# API-Key erstellen: https://app.tavily.com
TAVILY_API_KEY=

# GitLab - Personal Access Token (gitlab Skill)
# Token erstellen: https://gitlab.com/-/user_settings/personal_access_tokens
# Scopes: read_api, read_repository (zusaetzlich write_repository / api fuer Schreibzugriff)
# Fuer self-hosted Instanzen zusaetzlich GITLAB_HOST setzen (z. B. https://gitlab.example.com)
GITLAB_TOKEN=
GITLAB_HOST=
